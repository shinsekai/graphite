{
  "extends": "@graphite/config/tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["bun-types"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
