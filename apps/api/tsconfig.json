{
  "extends": "@graphite/config/tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "lib": ["ES2022"],
    "types": ["bun-types"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "outDir": "./dist",
    "noEmit": false,
    "composite": true,
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"],
  "references": [{ "path": "../../packages/db" }, { "path": "../../packages/shared" }]
}
