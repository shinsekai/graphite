{
  "extends": "@graphite/config/tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "lib": ["ES2022"],
    "types": ["bun-types"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
