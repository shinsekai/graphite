{
  "name": "@graphite/api",
  "version": "0.1.0",
  "private": true,
  "description": "Graphite API server (Hono + Bun)",
  "type": "module",
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "tsc",
    "check": "biome check src",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1017.0",
    "@graphite/db": "workspace:*",
    "@graphite/shared": "workspace:*",
    "hono": "^4.7.6",
    "zod": "^4.0.8"
  },
  "devDependencies": {
    "@graphite/config": "workspace:*",
    "bun-types": "^1.3.11",
    "drizzle-orm": "^0.40.1",
    "typescript": "^5.8.0",
    "vitest": "^3.0.7",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
