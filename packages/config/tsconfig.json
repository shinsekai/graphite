{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "allowImportingTsExtensions": false,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": false,
    "paths": {
      "@graphite/web": ["../../apps/web/src"],
      "@graphite/api": ["../../apps/api/src"],
      "@graphite/db": ["../../packages/db/src"],
      "@graphite/shared": ["../../packages/shared/src"],
      "@graphite/config": ["."]
    }
  },
  "exclude": ["node_modules", "dist", ".turbo", "coverage"]
}
